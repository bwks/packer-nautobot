#cloud-config

# Hostname
hostname: nautobot
fqdn: nautobot.local

# User configuration - ubuntu user with password auth for Packer SSH
users:
  - name: ubuntu
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: sudo
    shell: /bin/bash
    lock_passwd: false

# Set plain-text password for build-time SSH access
chpasswd:
  users:
    - name: ubuntu
      password: ubuntu
      type: text
  expire: false

# Enable SSH password authentication so Packer can connect
ssh_pwauth: true

# Grow root partition to fill the resized disk
growpart:
  mode: auto
  devices: ["/"]
  ignore_growroot_disabled: true

resize_rootfs: true

# Disable unattended upgrades / apt timers to prevent apt lock during build
bootcmd:
  - systemctl stop unattended-upgrades.service || true
  - systemctl disable unattended-upgrades.service || true
  - systemctl stop apt-daily.timer apt-daily-upgrade.timer || true
  - systemctl disable apt-daily.timer apt-daily-upgrade.timer || true
  - systemctl kill --kill-who=all apt-daily.service apt-daily-upgrade.service || true

# Suppress periodic apt activity
apt:
  conf: |
    APT::Periodic::Update-Package-Lists "0";
    APT::Periodic::Unattended-Upgrade "0";
    APT::Periodic::AutocleanInterval "0";
    APT::Periodic::Download-Upgradeable-Packages "0";
